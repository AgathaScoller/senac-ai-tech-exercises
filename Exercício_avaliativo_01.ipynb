      "source": [
        "dados = [1, 2, 2, 3, 3, 3, 4, 4, 5]\n",
        "\n",
        "frequencia = {}\n",
        "\n",
        "for n in dados:\n",
        "    if n in frequencia:\n",
        "        frequencia[n] += 1\n",
        "    else:\n",
        "        frequencia[n] = 1\n",
        "\n",
        "for numero, qtd in frequencia.items():\n",
        "    print(f\"{numero} aparece {qtd} vez(es)\")"
      ]
